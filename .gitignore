# Trusted Midman - Git Ignore File

# PHP files (keep these)
!*.php

# Database
*.sql
*.db
*.sqlite

# Logs
*.log
error.log
access.log

# Temporary files
*.tmp
*.temp
*.cache

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Config files with sensitive data
includes/config.php
.env
.env.local

# Upload directories
uploads/
images/uploads/

# Node modules (if using npm)
node_modules/

# Composer (if using)
vendor/

# Backup files
*.bak
*.backup
