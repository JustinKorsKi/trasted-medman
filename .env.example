# Trusted Midman local environment template
# Copy this file to .env and set real values.

DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=trusted_midman

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=no-reply@trustedmidman.local
SMTP_FROM_NAME=Trusted Midman
